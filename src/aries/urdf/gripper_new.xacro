<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <joint name="arm_gripper_base_joint" type="fixed">
        <parent link="link6"/>
        <child link="gripper_base_link"/>
        <origin xyz="0.0 0.0 0.05223" rpy="0.0 0.0 0.523599"/>
    </joint>


    <!--gripper base Link -->
    <link name="gripper_base_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="1.5363204791731" />
            <inertia
                ixx="0.242660790998556"
                ixy="-9.00009815481889E-05"
                ixz="0.0234683038167963"
                iyy="0.514730499629884"
                iyz="2.70300300277055E-11"
                izz="0.664242254581203" />
        </inertial>
        <visual>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_base.stl" />
            </geometry>
            <material
                name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_base.stl" />
            </geometry>
        </collision>
    </link>


    <!--gripper_gear_left Link -->
    <link name="gripper_gear_left_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="1.5363204791731" />
            <inertia
                ixx="0.242660790998556"
                ixy="-9.00009815481889E-05"
                ixz="0.0234683038167963"
                iyy="0.514730499629884"
                iyz="2.70300300277055E-11"
                izz="0.664242254581203" />
        </inertial>
        <visual>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_gear_left.stl" />
            </geometry>
            <material
                name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_gear_left.stl" />
            </geometry>
        </collision>
    </link>

    <joint name="gripper_gear_left_joint" type="revolute">
        <parent link="gripper_base_link"/>
        <child link="gripper_gear_left_link"/>
        <origin xyz="-0.024 0.00838 0.090" rpy="-1.57 -1.57 0.0"/>
        <axis xyz="0 0 1"/>
        <limit effort="500" velocity="1.0" lower="0.07" upper="-1.57"/>
        <dynamics damping="10" friction="2"/>
    </joint>

    <!--gripper_gear_right Link -->
    <link name="gripper_gear_right_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="1.5363204791731" />
            <inertia
                ixx="0.242660790998556"
                ixy="-9.00009815481889E-05"
                ixz="0.0234683038167963"
                iyy="0.514730499629884"
                iyz="2.70300300277055E-11"
                izz="0.664242254581203" />
        </inertial>
        <visual>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_gear_right.stl" />
            </geometry>
            <material
                name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_gear_right.stl" />
            </geometry>
        </collision>
    </link>

    <joint name="gripper_gear_right_joint" type="revolute">
        <parent link="gripper_base_link"/>
        <child link="gripper_gear_right_link"/>
        <origin xyz="0.024 0.00838 0.090" rpy="-1.57 -1.57 0.0"/>
        <axis xyz="0 0 -1"/>
        <limit effort="500" velocity="1.0" lower="-0.5" upper="0.5"/>
        <dynamics damping="10" friction="2"/>
        <mimic joint="gripper_gear_left_joint" multiplier="1.0" offset="0.0"/>
    </joint>
    
    <!--gripper_left Link -->
    <link name="gripper_left_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="1.5363204791731" />
            <inertia
                ixx="0.242660790998556"
                ixy="-9.00009815481889E-05"
                ixz="0.0234683038167963"
                iyy="0.514730499629884"
                iyz="2.70300300277055E-11"
                izz="0.664242254581203" />
        </inertial>
        <visual>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_link_left.stl" />
            </geometry>
            <material
                name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_link_left.stl" />
            </geometry>
        </collision>
    </link>

    <joint name="gripper_link_left_joint" type="revolute">
        <parent link="gripper_base_link"/>
        <child link="gripper_left_link"/>
        <origin xyz="-0.012 0.00838 0.123" rpy="-1.57 -1.57 0.0"/>
        <axis xyz="0 0 1"/>
        <limit effort="500" velocity="1.0" lower="-0.5" upper="0.5"/>
        <dynamics damping="10" friction="2"/>
        <mimic joint="gripper_gear_left_joint" multiplier="1.0" offset="0.0"/>
    </joint>

    <!--gear tip coupler left (connects gear far end to bucket pivot 1) -->
    <link name="gripper_gear_tip_left_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="0.01" />
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
        </inertial>
    </link>

    <joint name="gripper_gear_tip_left_joint" type="fixed">
        <parent link="gripper_gear_left_link"/>
        <child link="gripper_gear_tip_left_link"/>
        <origin xyz="0.089 0.0 0.005" rpy="0.0 0.0 0.0"/>
    </joint>

    <!--gripper_right Link -->
    <link name="gripper_right_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="1.5363204791731" />
            <inertia
                ixx="0.242660790998556"
                ixy="-9.00009815481889E-05"
                ixz="0.0234683038167963"
                iyy="0.514730499629884"
                iyz="2.70300300277055E-11"
                izz="0.664242254581203" />
        </inertial>
        <visual>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_link_right.stl" />
            </geometry>
            <material
                name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_link_right.stl" />
            </geometry>
        </collision>
    </link>

    <joint name="gripper_link_right_joint" type="revolute">
        <parent link="gripper_base_link"/>
        <child link="gripper_right_link"/>
        <origin xyz="0.012 0.00838 0.123" rpy="-1.57 -1.57 0.0"/>
        <axis xyz="0 0 -1"/>
        <limit effort="500" velocity="1.0" lower="-0.5" upper="0.5"/>
        <dynamics damping="10" friction="2"/>
        <mimic joint="gripper_gear_left_joint" multiplier="1.0" offset="0.0"/>
    </joint>

    <!--gear tip coupler right (connects gear far end to bucket pivot 1) -->
    <link name="gripper_gear_tip_right_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="0.01" />
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
        </inertial>
    </link>

    <joint name="gripper_gear_tip_right_joint" type="fixed">
        <parent link="gripper_gear_right_link"/>
        <child link="gripper_gear_tip_right_link"/>
        <origin xyz="0.089 0.0 0.005" rpy="0.0 0.0 0.0"/>
    </joint>

    <!--gripper_bucket_left Link -->
    <link name="gripper_bucket_left_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="1.5363204791731" />
            <inertia
                ixx="0.242660790998556"
                ixy="-9.00009815481889E-05"
                ixz="0.0234683038167963"
                iyy="0.514730499629884"
                iyz="2.70300300277055E-11"
                izz="0.664242254581203" />
        </inertial>
        <visual>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_bucket.stl" />
            </geometry>
            <material
                name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_bucket.stl" />
            </geometry>
        </collision>
    </link>

    <joint name="gripper_bucket_left_joint" type="revolute">
        <parent link="gripper_gear_tip_left_link"/>
        <child link="gripper_bucket_left_link"/>
        <origin xyz="-0.003437 0.0 0.0125" rpy="0.0 1.57 0.0"/>
        <axis xyz="1 0 0"/>
        <limit effort="500" velocity="1.0" lower="-1.57" upper="1.57"/>
        <dynamics damping="10" friction="2"/>
        <mimic joint="gripper_gear_left_joint" multiplier="1.0" offset="0.0"/>
    </joint>

    <!--link tip coupler left (aligns with bucket pivot 2) -->
    <link name="gripper_link_tip_left_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="0.01" />
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
        </inertial>
    </link>

    <joint name="gripper_link_tip_left_joint" type="fixed">
        <parent link="gripper_left_link"/>
        <child link="gripper_link_tip_left_link"/>
        <origin xyz="0.091 0.0 0.005" rpy="0.0 0.0 0.0"/>
    </joint>

    <!--gripper_bucket_right Link -->
    <link name="gripper_bucket_right_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="1.5363204791731" />
            <inertia
                ixx="0.242660790998556"
                ixy="-9.00009815481889E-05"
                ixz="0.0234683038167963"
                iyy="0.514730499629884"
                iyz="2.70300300277055E-11"
                izz="0.664242254581203" />
        </inertial>
        <visual>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_bucket.stl" />
            </geometry>
            <material
                name="">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0"
                    rpy="0 0 0" />
            <geometry>
                <mesh filename="${mesh_location}/gripper/gripper_bucket.stl" />
            </geometry>
        </collision>
    </link>

    <joint name="gripper_bucket_right_joint" type="revolute">
        <parent link="gripper_gear_tip_right_link"/>
        <child link="gripper_bucket_right_link"/>
        <origin xyz="-0.003437 0.0 0.0125" rpy="0.0 -1.57 3.14159"/>
        <axis xyz="1 0 0"/>
        <limit effort="500" velocity="1.0" lower="-1.57" upper="1.57"/>
        <dynamics damping="10" friction="2"/>
        <mimic joint="gripper_gear_left_joint" multiplier="1.0" offset="0.0"/>
    </joint>

    <!--link tip coupler right (fourth pivot of four-bar) -->
    <link name="gripper_link_tip_right_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="0.01" />
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
        </inertial>
    </link>

    <joint name="gripper_link_tip_right_joint" type="fixed">
        <parent link="gripper_right_link"/>
        <child link="gripper_link_tip_right_link"/>
        <origin xyz="0.091 0.0 0.005" rpy="0.0 0.0 0.0"/>
    </joint>

    <!-- Visual constraint markers to show four-bar connection -->
    <link name="fourbar_constraint_visual_left">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.001" length="0.015"/>
            </geometry>
            <material name="constraint_color">
                <color rgba="1 0 0 0.5"/>
            </material>
        </visual>
    </link>

    <joint name="fourbar_constraint_visual_left_joint" type="fixed">
        <parent link="gripper_link_tip_left_link"/>
        <child link="fourbar_constraint_visual_left"/>
        <origin xyz="0.0 -0.0075 0.0" rpy="1.57 0 0"/>
    </joint>

    <link name="fourbar_constraint_visual_right">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.001" length="0.015"/>
            </geometry>
            <material name="constraint_color">
                <color rgba="1 0 0 0.5"/>
            </material>
        </visual>
    </link>

    <joint name="fourbar_constraint_visual_right_joint" type="fixed">
        <parent link="gripper_link_tip_right_link"/>
        <child link="fourbar_constraint_visual_right"/>
        <origin xyz="0.0 0.0075 0.0" rpy="1.57 0 0"/>
    </joint>

    
</robot>